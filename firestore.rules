rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function signedInAs(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isIntInRange(v, lo, hi) {
      return v is int && v >= lo && v <= hi;
    }

    // Validates a meal document written by the client. Mirrors the clamping
    // done in MealResult so a direct API call can't store garbage values.
    function isValidMeal(d) {
      return d.food_name is string
          && d.food_name.size() > 0
          && d.food_name.size() <= 100
          && isIntInRange(d.calories, 0, 10000)
          && isIntInRange(d.protein_g, 0, 1000)
          && isIntInRange(d.carbs_g, 0, 1000)
          && isIntInRange(d.fat_g, 0, 1000);
    }

    // Validate a daily_log write. Each field is optional (the doc is built up
    // by separate merge writes — meals add consumed_*, the dashboard adds
    // steps_net / water_liters), but any field that IS present must be sane.
    function dailyNumOk(d, key, lo, hi) {
      return !(key in d)
          || (d[key] is number && d[key] >= lo && d[key] <= hi);
    }

    function isValidDailyLog(d) {
      return dailyNumOk(d, 'consumed_calories', 0, 1000000)
          && dailyNumOk(d, 'consumed_protein_g', 0, 1000000)
          && dailyNumOk(d, 'consumed_carbs_g', 0, 1000000)
          && dailyNumOk(d, 'consumed_fat_g', 0, 1000000)
          && dailyNumOk(d, 'steps_net', 0, 1000000)
          && dailyNumOk(d, 'water_liters', 0, 100);
    }

    // A user may only touch their OWN document tree, and only while signed in.
    // request.auth is null for unauthenticated callers, so all access is denied
    // before login — regardless of what the client UI allows.
    match /users/{userId} {

      // The profile document itself.
      allow read, write: if signedInAs(userId);

      // ── Meal history: validate the data on create ──
      match /meal_history/{mealId} {
        allow read, delete: if signedInAs(userId);
        allow create, update: if signedInAs(userId)
                              && isValidMeal(request.resource.data);
      }

      // ── Daily running totals (written via increment/merge) ──
      match /daily_logs/{dateId} {
        allow read: if signedInAs(userId);
        allow write: if signedInAs(userId)
                     && isValidDailyLog(request.resource.data);
      }

      // ── Body-weight history (one doc per day, latest wins) ──
      match /weight_logs/{dateId} {
        allow read, delete: if signedInAs(userId);
        allow create, update: if signedInAs(userId)
                              && request.resource.data.weight_kg is number
                              && request.resource.data.weight_kg > 0
                              && request.resource.data.weight_kg <= 500;
      }

      // ── Gym: workout sessions ──
      match /workouts/{workoutId} {
        allow read, write: if signedInAs(userId)
                           && (request.method == 'delete'
                               || request.resource.data.name is string);
      }

      // ── Gym: user-created custom exercises ──
      match /custom_exercises/{exerciseId} {
        allow read, delete: if signedInAs(userId);
        allow create, update: if signedInAs(userId)
                              && request.resource.data.name is string
                              && request.resource.data.name.size() <= 60
                              && request.resource.data.isCustom == true;
      }

      // ── Gym: reusable routines/templates ──
      match /routines/{routineId} {
        allow read, write: if signedInAs(userId);
      }

      // No other subcollections are expected — deny anything unlisted.
      match /{document=**} {
        allow read, write: if false;
      }
    }

    // ── Coach Directory (§4.5) ──
    // Any signed-in user may browse coaches; a trainer may only create/edit/
    // delete their OWN profile (doc id == their uid). Writes are validated so a
    // direct API call can't store garbage.
    match /coaches/{coachId} {
      allow read: if request.auth != null;
      allow delete: if signedInAs(coachId);
      allow create, update: if signedInAs(coachId)
          && request.resource.data.uid == coachId
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() > 0
          && request.resource.data.displayName.size() <= 50
          && request.resource.data.hourlyRateMyr is int
          && request.resource.data.hourlyRateMyr >= 0
          && request.resource.data.hourlyRateMyr <= 100000
          && request.resource.data.specializations is list
          && request.resource.data.contactValue is string
          && request.resource.data.contactValue.size() <= 200
          && request.resource.data.bio.size() <= 1000;
    }

    // Everything outside /users is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
